    "mobile.review.caughtUpMessage": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Ш№ЩҶШҜЩ…Ш§ ЩҠЩҒШ№Щ‘Щ„ Ш§Щ„Щ…ШҜШұЩ‘ШіЩҲЩҶ Ш§Щ„ШӘЩғШұШ§Шұ Ш§Щ„Щ…ШӘШЁШ§Ш№ШҜ ЩҒЩҠ Щ…ЩӮШұШұ ЩҲЩҠШөЩҶЩ‘ЩҒЩҲЩҶ Ш§Щ„ШЈШіШҰЩ„Ш©ШҢ ШӘШёЩҮШұ Ш§Щ„Ш№ЩҶШ§ШөШұ Ш§Щ„Щ…ШіШӘШӯЩӮШ© ЩҮЩҶШ§."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When instructors enable SRS on a course and tag questions, due items appear here."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[ЕҙДҘГ«Гұ Г®ГұЕЎЕЈЕ•Г»Г§ЕЈГ¶Е•ЕЎ Г«ГұГӨЙ“ДҫГ« Е ЕҳЕ  Г¶Гұ ГӨ Г§Г¶Г»Е•ЕЎГ« ГӨГұГ° ЕЈГӨДЎ Д·Г»Г«ЕЎЕЈГ®Г¶ГұЕЎ, Д‘Г»Г« Г®ЕЈГ«ЙұЕЎ ГӨГҫГҫГ«ГӨЕ• ДҘГ«Е•Г«.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando los instructores activan SRS en un curso y etiquetan preguntas, los elementos pendientes aparecen aquГӯ."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque les enseignants activent la SRS sur un cours et Г©tiquettent des questions, les Г©lГ©ments Г  rГ©viser apparaissent ici."
          }
        }
      }
    },
