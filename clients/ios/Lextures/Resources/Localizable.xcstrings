    "mobile.attendance.disabled.message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ЩҒШ№Щ‘Щ„ Ш§Щ„ШӯШ¶ЩҲШұ ЩҒЩҠ ШҘШ№ШҜШ§ШҜШ§ШӘ Ш§Щ„Щ…ЩӮШұШұ Щ„Ш§ШіШӘШ®ШҜШ§Щ… Ш§Щ„ШӘШіШ¬ЩҠЩ„ ЩҲШ§Щ„ШҘШЁЩ„Ш§Шә Ш§Щ„Ш°Ш§ШӘЩҠ."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on attendance in course settings to use roll call and self-report check-ins."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "ЕўЕ©Е•Еү Г¶Гұ ГҘЕЈЕЈГ©ГұГ°ГҘГұГ§Г© Г®Гұ Г§Г¶Г»Е•ЕЎГ© ЕЎГ©ЕЈЕЈГ®ГұДқЕЎ ЕЈГ¶ Г»ЕЎГ© Е•Г¶ДјДј Г§ГҘДјДј ГҘГұГ° ЕЎГ©ДјЖ’-Е•Г©ГҫГ¶Е•ЕЈ Г§ДҘГ©Г§Д·-Г®ГұЕЎ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa la asistencia en la configuraciГіn del curso para usar lista y auto-registro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez la prГ©sence dans les paramГЁtres du cours pour utiliser l'appel et l'auto-dГ©claration."
          }
        }
      }
    },
