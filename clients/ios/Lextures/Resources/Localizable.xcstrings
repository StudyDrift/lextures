    "mobile.sessions.description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن لهذه الأجهزة والمتصفحات الوصول إلى حسابك. سجّل الخروج مما لا تعرفه."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These devices and browsers can access your account. Sign out anything you do not recognize."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Ţĥëšë ðëṽîçëš äñð ḅŕöŵšëŕš çäñ äççëšš ýöûŕ äççöüñţ.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos dispositivos y navegadores pueden acceder a tu cuenta. Cierra sesión en los que no reconozcas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces appareils et navigateurs peuvent accéder à votre compte. Déconnectez ceux que vous ne reconnaissez pas."
          }
        }
      }
    },
