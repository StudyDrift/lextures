        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[ГӣЕЎГ« ЕЈДҘГ« Г«ЙұГӨГ®Дҫ ГҝГ¶Г»Е• Г§Г¶ГјЕ•ЕЎГ« Г¶Е• ЕЎДүДҘГ¶Г¶Дҫ Г»ЕЎГ«ЕЎ. Е Е Г– Г¶ГҫЕЈГ®Г¶ГұЕЎ ГӨГҫГҫГ«ГӨЕ• ЕөДҘГ«Гұ ГҝГ¶Г»Е• Г¶Е•ДЎГӨГұГ®ЕҫГӨЕЈГ®Г¶Гұ Г§Г¶ГұГұГ«Г§ЕЈЕЎ ЕЈДҘГ«Йұ.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el correo que usa tu curso o escuela. Las opciones de SSO aparecen cuando tu organizaciГіn las conecta."
          }
        },
        "fr": {
