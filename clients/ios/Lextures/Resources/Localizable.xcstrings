        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تسجيل الخروج من جميع الجلسات الأخرى؟ ستحتاج الأجهزة الأخرى إلى تسجيل الدخول مجددًا. يبقى هذا الجهاز مسجّل الدخول."
