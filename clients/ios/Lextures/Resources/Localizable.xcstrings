    "mobile.profile.clearCacheMessage" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يزيل القراءات والتنزيلات المخزّنة مؤقتًا من هذا الجهاز. تبقى التغييرات في قائمة الانتظار حتى تتم مزامنتها."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Removes cached reads and downloads from this device. Queued changes are kept until they sync."
          }
        },
        "en-XA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Ŕëɱöṽëš çäçĥëđ ŕëäđš äñđ đöẅñľöäđš.]"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina lecturas y descargas en caché de este dispositivo. Los cambios en cola se conservan hasta sincronizarse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime les lectures et téléchargements en cache sur cet appareil. Les modifications en file d'attente sont conservées jusqu'à la synchronisation."
          }
        }
      }
    },
