# Copy to mobile-dev.env and adjust for your machine (mobile-dev.env is gitignored).
# Then run: bash clients/scripts/setup-mobile-dev.sh
#
# Host and port for the Go API on your dev machine (server/.env PORT=8080).
API_HOST=localhost
API_PORT=8080

# setup-mobile-dev.sh maps localhost to platform-specific loopback addresses:
#   iOS Simulator  → http://127.0.0.1:8080
#   Android Emulator → http://10.0.2.2:8080
#
# For a physical device, set API_HOST to your Mac/PC LAN IP instead, e.g.:
# API_HOST=192.168.1.42
