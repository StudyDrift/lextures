    "mobile.learnerProfile.howItWorks.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Your learner profile is built automatically from your activity across courses. It is never entered manually, and you own it. Each insight shows where it came from, when it was last updated, and how confident we are."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your learner profile is built automatically from your activity across courses. It is never entered manually, and you own it. Each insight shows where it came from, when it was last updated, and how confident we are."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "Your learner profile is built automatically from your activity across courses. It is never entered manually, and you own it. Each insight shows where it came from, when it was last updated, and how confident we are."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Your learner profile is built automatically from your activity across courses. It is never entered manually, and you own it. Each insight shows where it came from, when it was last updated, and how confident we are."
          }
        },
        "fr": {
