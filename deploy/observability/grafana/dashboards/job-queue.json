{
  "uid": "lextures-job-queue",
  "title": "Lextures — Job Queue",
  "tags": ["lextures", "jobs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Queue depth by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "lextures_job_queue_jobs", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dead letters",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 10 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "lextures_job_queue_dead_letters", "legendFormat": "dead letters" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Backlog by job type",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "lextures_job_queue_depth_by_type", "legendFormat": "{{job_type}}" }
      ]
    }
  ]
}
