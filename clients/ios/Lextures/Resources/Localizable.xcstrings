    "mobile.review.caughtUpMessage": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما يفعّل المدرّسون التكرار المتباعد في مقرر ويصنّفون الأسئلة، تظهر العناصر المستحقة هنا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When instructors enable SRS on a course and tag questions, due items appear here."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Ŵĥëñ îñšţŕûçţöŕš ëñäɓľë ŠŘŠ öñ ä çöûŕšë äñð ţäġ ķûëšţîöñš, đûë îţëɱš äþþëäŕ ĥëŕë.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando los instructores activan SRS en un curso y etiquetan preguntas, los elementos pendientes aparecen aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque les enseignants activent la SRS sur un cours et étiquettent des questions, les éléments à réviser apparaissent ici."
          }
        }
      }
    },
