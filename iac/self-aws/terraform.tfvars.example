project_name = "lextures"
environment  = "staging"
aws_region   = "us-east-1"

# Cost-focused defaults (free-tier eligible sizes where AWS still offers them):
# db_instance_class       = "db.t4g.micro"
# db_allocated_storage_gb = 20
# redis_node_type         = "cache.t3.micro"
# db_multi_az             = false
# enable_nat_gateway      = false   # public-subnet Fargate; set true for private tasks

# Static web (S3 + CloudFront) — default on
# enable_static_site = true
# web_bucket_force_destroy = true  # staging only
# cloudfront_price_class   = "PriceClass_100"
#
# Custom domain (optional). Leave web_domain_names empty for free *.cloudfront.net cert.
# Terraform will request a DNS-validated ACM cert in us-east-1 when domains are set
# and web_acm_certificate_arn is empty — then `terraform output acm_dns_validation_records`.
# web_domain_names  = ["beta.example.com"]
# public_web_origin = "https://beta.example.com"
# Optional: use an existing us-east-1 ACM cert instead of letting Terraform create one:
# web_acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"

# API + web on ECS Fargate (images from .github/workflows/publish-images.yml)
# enable_ecs   = true
# server_image = "ghcr.io/YOUR_ORG/lextures/server:latest"
# web_image    = "ghcr.io/YOUR_ORG/lextures/web:latest"
# Private GHCR: set both (PAT with read:packages). Leave empty if packages are public.
# registry_username = ""
# registry_password = ""

# public_web_origin = "https://app.example.com"  # optional override; default = CloudFront URL
# jwt_secret        = ""  # empty = auto-generate into Secrets Manager
# platform_secrets_key = ""  # empty = auto-generate (base64 32-byte AES key for SMTP/BYOK at rest)
# # Or pin explicitly: platform_secrets_key = "..."  # openssl rand -base64 32 — keep stable across applies
# First password signup with this email gets Global Admin (only when no human users yet):
# bootstrap_admin_email = "you@example.com"

# Amazon SES (transactional email). Resources are created when ses_domain is set.
# enable_ses   = true
# ses_domain   = "example.com"
# ses_from_email = "no-reply@example.com"   # default: no-reply@<ses_domain>
# ses_mail_from_subdomain = "bounce"        # optional custom MAIL FROM
# After apply: terraform output ses_dns_records  → add DKIM CNAMEs (DNS only in Cloudflare)
# New SES accounts start in sandbox (verified recipients only) until production access is approved.

# course_files_bucket_force_destroy = true  # staging only
