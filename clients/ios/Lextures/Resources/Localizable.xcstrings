    "mobile.courseInvite.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اقبل الدعوة للانضمام ومشاهدة محتوى المقرر، أو ارفضها لإزالته من قائمتك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accept the invitation to join and see the course content, or decline to remove it from your list."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Àççépt thé îñvîtàtîöñ tö jöîñ àñd šéé thé çöüŕšé çöñtéñt, öŕ déçlîñé tö ŕémövé ît fŕöm ýöüŕ lîšt.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acepta la invitación para unirte y ver el contenido del curso, o recházala para quitarlo de tu lista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceptez l'invitation pour rejoindre le cours et voir son contenu, ou refusez pour le retirer de votre liste."
          }
        }
      }
    },
