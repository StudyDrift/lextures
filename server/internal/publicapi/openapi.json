{
  "openapi": "3.1.0",
  "info": {
    "title": "Lextures Public API",
    "description": "Versioned REST API for third-party integrations. Authenticate with `Authorization: Bearer <ltk_ token>`.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/api/v1", "description": "API v1" }
  ],
  "tags": [
    { "name": "meta", "description": "OpenAPI spec and documentation" },
    { "name": "courses", "description": "Course resources" },
    { "name": "enrollments", "description": "Course enrollments" },
    { "name": "users", "description": "User directory" },
    { "name": "assignments", "description": "Assignments" },
    { "name": "grades", "description": "Posted grades" },
    { "name": "graphql", "description": "GraphQL schema stub" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API token (ltk_…)"
      }
    },
    "schemas": {
      "Problem": {
        "type": "object",
        "required": ["type", "title", "status"],
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" },
          "instance": { "type": "string" }
        }
      },
      "CollectionResponse": {
        "type": "object",
        "required": ["data", "meta", "links"],
        "properties": {
          "data": { "type": "array", "items": { "type": "object" } },
          "meta": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "cursor": { "type": "string" }
            }
          },
          "links": {
            "type": "object",
            "properties": {
              "next": { "type": "string" },
              "prev": { "type": "string" }
            }
          }
        }
      },
      "Course": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "courseCode": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "published": { "type": "boolean" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "displayName": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      },
      "Enrollment": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "userId": { "type": "string", "format": "uuid" },
          "role": { "type": "string" },
          "state": { "type": "string" }
        }
      },
      "Assignment": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "courseId": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "dueAt": { "type": "string", "format": "date-time" }
        }
      },
      "Grade": {
        "type": "object",
        "properties": {
          "courseId": { "type": "string", "format": "uuid" },
          "studentUserId": { "type": "string", "format": "uuid" },
          "moduleItemId": { "type": "string", "format": "uuid" },
          "pointsEarned": { "type": "string" }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid bearer token",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      },
      "Forbidden": {
        "description": "Insufficient token scope",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded",
        "headers": {
          "Retry-After": { "schema": { "type": "integer" } }
        },
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/Problem" }
          }
        }
      }
    }
  },
  "paths": {
    "/openapi.json": {
      "get": {
        "tags": ["meta"],
        "summary": "OpenAPI 3.1 specification",
        "responses": {
          "200": { "description": "OpenAPI JSON document" }
        }
      }
    },
    "/docs": {
      "get": {
        "tags": ["meta"],
        "summary": "Swagger UI",
        "responses": {
          "200": { "description": "Swagger UI HTML" }
        }
      }
    },
    "/redoc": {
      "get": {
        "tags": ["meta"],
        "summary": "ReDoc UI",
        "responses": {
          "200": { "description": "ReDoc HTML" }
        }
      }
    },
    "/courses": {
      "get": {
        "tags": ["courses"],
        "summary": "List courses",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "maximum": 100, "default": 25 } },
          { "name": "fields[courses]", "in": "query", "schema": { "type": "string" }, "description": "Sparse fieldset (comma-separated)" }
        ],
        "responses": {
          "200": {
            "description": "Paginated course collection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CollectionResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/courses/{id}": {
      "get": {
        "tags": ["courses"],
        "summary": "Get course by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Course",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Course" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "description": "Course not found" }
        }
      }
    },
    "/courses/{id}/enrollments": {
      "get": {
        "tags": ["enrollments"],
        "summary": "List course enrollments",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "maximum": 100, "default": 25 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated enrollment collection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CollectionResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["users"],
        "summary": "Get user by ID",
        "description": "Email and full name require the `pii:read` scope.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "User",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/assignments": {
      "get": {
        "tags": ["assignments"],
        "summary": "List assignments",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "maximum": 100, "default": 25 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated assignment collection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CollectionResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/grades": {
      "get": {
        "tags": ["grades"],
        "summary": "List posted grades",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "maximum": 100, "default": 25 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated grade collection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CollectionResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/graphql": {
      "get": {
        "tags": ["graphql"],
        "summary": "GraphQL schema stub (query-only)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "GraphQL SDL text" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  }
}
