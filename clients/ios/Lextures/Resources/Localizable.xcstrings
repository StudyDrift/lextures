    "auth.login.serverUnreachable": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ШӘШ№Ш°Шұ Ш§Щ„ЩҲШөЩҲЩ„ ШҘЩ„Щү Ш§Щ„Ш®Ш§ШҜЩ…. ЩҮЩ„ ЩҲШ§Ш¬ЩҮШ© API ЩӮЩҠШҜ Ш§Щ„ШӘШҙШәЩҠЩ„Шҹ"
