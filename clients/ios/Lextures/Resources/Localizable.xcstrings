        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[ГҮГ¶ГјДҫД‘ ГұГ¶ЕЈ Е•Г«ГӨГ§ДҘ ЕЈДҘГ« ЕЎГ«Е•б№ҪГ«Е•. ГҺЕЎ ЕЈДҘГ« Г„ГһГҺ Е•ГјГұГұГ®ГұДЎ?]"
