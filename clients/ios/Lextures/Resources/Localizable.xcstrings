    "auth.getStarted.schoolCodeSubtitle" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "توفر مدرستك أو منطقتك رمزًا قصيرًا لتسجيل الدخول. أدخله للاتصال ببيئة Lextures الخاصة بمدرستك."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your school or district provides a short code for sign-in. Enter it below to connect to your school's Lextures environment."
          }
        },
        "en-XA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Your school or district provides a short code for sign-in. Enter it below to connect to your school's Lextures environment.]"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu escuela o distrito proporciona un código corto para iniciar sesión. Introdúcelo para conectar con su entorno de Lextures."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre établissement fournit un code court pour la connexion. Saisissez-le pour rejoindre son environnement Lextures."
          }
        }
      }
    },
