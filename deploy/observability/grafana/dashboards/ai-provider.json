{
  "uid": "lextures-ai-provider",
  "title": "Lextures — AI Provider Usage",
  "tags": ["lextures", "ai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(lextures_ai_provider_calls_total, provider)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "AI calls by provider/model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, model) (rate(lextures_ai_provider_calls_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "AI error rate by provider",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(lextures_ai_provider_calls_total{provider=~\"$provider\",outcome=\"error\"}[5m])) / clamp_min(sum by (provider) (rate(lextures_ai_provider_calls_total{provider=~\"$provider\"}[5m])), 1)",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "AI latency p95 by provider/model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (provider, model, le) (rate(lextures_ai_provider_latency_seconds_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Estimated AI spend ($/h)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, model) (rate(lextures_ai_estimated_cost_dollars_total{provider=~\"$provider\"}[1h])) * 3600",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    }
  ]
}
