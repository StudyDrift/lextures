    "auth.login.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم البريد الإلكتروني الذي يستخدمه مقررك أو مدرستك. تظهر خيارات SSO عندما تربطها مؤسستك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the email your course or school uses. SSO options appear when your organization connects them."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Ûšë ţĥë ëɱäîľ ÿöûŕ çöüŕšë öŕ šĉĥööľ ûšëš. ŠŠÖ öþţîöñš äþþëäŕ ŵĥëñ ÿöûŕ öŕġäñîžäţîöñ çöññëçţš ţĥëɱ.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el correo que usa tu curso o escuela. Las opciones de SSO aparecen cuando tu organización las conecta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez l'e-mail de votre cours ou école. Les options SSO apparaissent lorsque votre organisation les connecte."
          }
        }
      }
    },
