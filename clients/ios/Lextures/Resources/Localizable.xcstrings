    "mobile.profile.clearCacheMessage": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ЩҠШІЩҠЩ„ Ш§Щ„ЩӮШұШ§ШЎШ§ШӘ ЩҲШ§Щ„ШӘЩҶШІЩҠЩ„Ш§ШӘ Ш§Щ„Щ…Ш®ШІЩ‘ЩҶШ© Щ…ШӨЩӮШӘЩӢШ§ Щ…ЩҶ ЩҮШ°Ш§ Ш§Щ„Ш¬ЩҮШ§ШІ. ШӘШЁЩӮЩү Ш§Щ„ШӘШәЩҠЩҠШұШ§ШӘ ЩҒЩҠ ЩӮШ§ШҰЩ…Ш© Ш§Щ„Ш§ЩҶШӘШёШ§Шұ ШӯШӘЩү ШӘШӘЩ… Щ…ШІШ§Щ…ЩҶШӘЩҮШ§."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Removes cached reads and downloads from this device. Queued changes are kept until they sync."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Е”Г«ЙұГ¶б№ҪГ«ЕЎ Г§ГӨГ§ДҘГ«Д‘ Е•Г«ГӨД‘ЕЎ ГӨГұД‘ Д‘Г¶бә…ГұДҫГ¶ГӨД‘ЕЎ.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina lecturas y descargas en cachГ© de este dispositivo. Los cambios en cola se conservan hasta sincronizarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime les lectures et tГ©lГ©chargements en cache sur cet appareil. Les modifications en file d'attente sont conservГ©es jusqu'Г  la synchronisation."
          }
        }
