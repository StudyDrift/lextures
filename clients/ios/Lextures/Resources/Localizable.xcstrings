    "auth.signup.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حساب واحد للمقررات والواجبات والرسائل. إذا كانت مدرستك تستخدم SSO، يمكنك تسجيل الدخول بهذه الطريقة لاحقًا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One account for courses, assignments, and messages. If your school uses SSO, you can sign in that way later."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Öñë äççöüñţ ƒöŕ çöüŕšëš, äššîġñɱëñţš, äñđ ɱëššäġëš.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una cuenta para cursos, tareas y mensajes. Si tu escuela usa SSO, podrás iniciar sesión así más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un compte pour les cours, devoirs et messages. Si votre école utilise la SSO, vous pourrez vous connecter ainsi plus tard."
          }
        }
      }
    },
