        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cerrar sesión en todos los demás dispositivos? Tendrán que volver a iniciar sesión. Este dispositivo permanecerá conectado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déconnecter toutes les autres sessions ? Les autres appareils devront se reconnecter. Cet appareil reste connecté."
