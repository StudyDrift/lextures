# Copy to `.env` in the repository root for Docker Compose (dev, prod, or base stack).
# Compose reads these variables for the `server` service.

# First password signup receives Global Admin only when this matches the signup email (trimmed, lowercased).
# Set before the first human user registers. If unset, use bootstrap-admin after signup (see docs/getting-started.md).
BOOTSTRAP_ADMIN_EMAIL=you@yourdomain.com

# Optional: serve Swagger UI and ReDoc for the public API at /api/v1/docs and /api/v1/redoc
# ENABLE_API_DOCS=true
# Optional: enable the versioned public REST API for ltk_ bearer tokens (also toggled in Settings → Global platform)
# PUBLIC_API_ENABLED=true
