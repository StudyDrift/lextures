    "mobile.sessions.signOutOthersConfirm": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تسجيل الخروج من جميع الجلسات الأخرى؟ ستحتاج الأجهزة الأخرى إلى تسجيل الدخول مجددًا. يبقى هذا الجهاز مسجّل الدخول."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign out all other sessions? Other browsers and devices will need to sign in again. This device stays signed in."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Šîġñ öûţ äľľ öţĥëŕ šëššîöñš?]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cerrar sesión en todos los demás dispositivos? Tendrán que volver a iniciar sesión. Este dispositivo permanecerá conectado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déconnecter toutes les autres sessions ? Les autres appareils devront se reconnecter. Cet appareil reste connecté."
          }
        }
      }
