    "mobile.sessions.description" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن لهذه الأجهزة والمتصفحات الوصول إلى حسابك. سجّل الخروج مما لا تعرفه."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These devices and browsers can access your account. Sign out anything you do not recognize."
          }
