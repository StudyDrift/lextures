    "mobile.admin.archivedCourses.description": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived courses are hidden from catalogs and search. Restore a course to bring it back, or permanently delete it to remove all content, files, submissions, and enrollments."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived courses are hidden from catalogs and search. Restore a course to bring it back, or permanently delete it to remove all content, files, submissions, and enrollments."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[Archived courses are hidden from catalogs and search. Restore a course to bring it back, or permanently delete it to remove all content, files, submissions, and enrollments.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived courses are hidden from catalogs and search. Restore a course to bring it back, or permanently delete it to remove all content, files, submissions, and enrollments."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
