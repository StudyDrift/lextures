          "stringUnit": {
            "state": "translated",
            "value": "[Ŕëɱöṽëš çäçĥëđ ŕëäđš äñđ đöẅñľöäđš.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina lecturas y descargas en caché de este dispositivo. Los cambios en cola se conservan hasta sincronizarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime les lectures et téléchargements en cache sur cet appareil. Les modifications en file d'attente sont conservées jusqu'à la synchronisation."
