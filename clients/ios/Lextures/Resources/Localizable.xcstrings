        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo conectar con el servidor. ВҝEstГЎ la API en ejecuciГіn?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de joindre le serveur. L'API est-elle en cours d'exГ©cution ?"
          }
        }
