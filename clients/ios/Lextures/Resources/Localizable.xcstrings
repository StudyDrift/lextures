    "mobile.courseInvite.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Ш§ЩӮШЁЩ„ Ш§Щ„ШҜШ№ЩҲШ© Щ„Щ„Ш§ЩҶШ¶Щ…Ш§Щ… ЩҲЩ…ШҙШ§ЩҮШҜШ© Щ…ШӯШӘЩҲЩү Ш§Щ„Щ…ЩӮШұШұШҢ ШЈЩҲ Ш§ШұЩҒШ¶ЩҮШ§ Щ„ШҘШІШ§Щ„ШӘЩҮ Щ…ЩҶ ЩӮШ§ШҰЩ…ШӘЩғ."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accept the invitation to join and see the course content, or decline to remove it from your list."
          }
        },
        "en-XA": {
          "stringUnit": {
            "state": "translated",
            "value": "[ГҖГ§Г§Г©pt thГ© Г®ГұvГ®tГ tГ®Г¶Гұ tГ¶ jГ¶Г®Гұ Г Гұd ЕЎГ©Г© thГ© Г§Г¶ГјЕ•ЕЎГ© Г§Г¶ГұtГ©Гұt, Г¶Е• dГ©Г§lГ®ГұГ© tГ¶ Е•Г©mГ¶vГ© Г®t fЕ•Г¶m ГҪГ¶ГјЕ• lГ®ЕЎt.]"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acepta la invitaciГіn para unirte y ver el contenido del curso, o rechГЎzala para quitarlo de tu lista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceptez l'invitation pour rejoindre le cours et voir son contenu, ou refusez pour le retirer de votre liste."
          }
        }
      }
    },
