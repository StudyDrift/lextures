        "en-XA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Ţĥëšë ðëṽîçëš äñð ḅŕöŵšëŕš çäñ äççëšš ýöûŕ äççöüñţ.]"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estos dispositivos y navegadores pueden acceder a tu cuenta. Cierra sesión en los que no reconozcas."
